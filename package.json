{
  "name": "direttore-workspace",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Workspace for the Direttore package family.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build -w @direttore/core",
    "build:react-query": "npm run build -w @direttore/react-query",
    "pack:core": "npm run pack:dry-run -w @direttore/core",
    "pack:react-query": "npm run pack:dry-run -w @direttore/react-query",
    "test": "npm test --workspaces --if-present",
    "test:core": "npm test -w @direttore/core",
    "test:react-query": "npm test -w @direttore/react-query",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:core": "npm run typecheck -w @direttore/core",
    "typecheck:react-query": "npm run typecheck -w @direttore/react-query"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
