{
  "name": "@direttore/react-query",
  "version": "0.1.0-alpha.2",
  "description": "TanStack React Query adapter for Direttore API endpoints.",
  "author": "Caian Keller",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caiankeller/direttore.git",
    "directory": "packages/react-query"
  },
  "homepage": "https://github.com/caiankeller/direttore",
  "bugs": {
    "url": "https://github.com/caiankeller/direttore/issues"
  },
  "keywords": [
    "api",
    "frontend",
    "orchestration",
    "fetch",
    "react",
    "react-query",
    "tanstack-query"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@direttore/core": "0.1.0-alpha.2"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.0",
    "react": "^19.2.7"
  },
  "engines": {
    "node": ">=18.17"
  }
}
